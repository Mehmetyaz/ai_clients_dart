{
  "categories": {
    "auth": {
      "patterns": ["identity", "auth"],
      "directory": "auth"
    },
    "collections": {
      "patterns": ["collection", "configuration"],
      "directory": "collections"
    },
    "databases": {
      "patterns": ["database"],
      "directory": "databases"
    },
    "tenants": {
      "patterns": ["tenant"],
      "directory": "tenants"
    },
    "records": {
      "patterns": ["add", "get", "query", "search", "delete", "upsert", "update", "record"],
      "directory": "records"
    },
    "metadata": {
      "patterns": ["heartbeat", "version", "health", "error", "include"],
      "directory": "metadata"
    }
  },
  "default_category": "common",
  "parent_model_patterns": {
    "Collection": [".*Configuration$"],
    "Request": [".*Payload$"]
  }
}
